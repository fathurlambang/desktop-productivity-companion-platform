{
  "$schema": "https://json.schemastore.org/electron-builder.json",
  "appId": "com.focuscompanion.app",
  "productName": "Focus Companion",
  "directories": {
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json",
    "!**/node_modules/**/{test,tests,__tests__,__mocks__,examples,demo,docs,doc}/**",
    "!**/node_modules/**/*.{md,txt,map,ts,yml,yaml}",
    "!**/node_modules/**/README*",
    "!**/node_modules/**/LICENSE*",
    "!**/node_modules/**/CHANGELOG*",
    "!**/node_modules/.bin/**",
    "!**/node_modules/.cache/**",
    "!**/node_modules/.package-lock.json",
    "!node_modules/drizzle-kit{,/**}",
    "!node_modules/@playwright{,/**}",
    "!node_modules/playwright{,/**}",
    "!node_modules/playwright-core{,/**}",
    "!node_modules/vitest{,/**}",
    "!node_modules/eslint{,/**}",
    "!node_modules/eslint-plugin-react-hooks{,/**}",
    "!node_modules/eslint-plugin-react-refresh{,/**}",
    "!node_modules/@typescript-eslint{,/**}",
    "!node_modules/prettier{,/**}",
    "!node_modules/typescript{,/**}",
    "!node_modules/vite{,/**}",
    "!node_modules/@vitejs{,/**}",
    "!node_modules/autoprefixer{,/**}",
    "!node_modules/postcss{,/**}",
    "!node_modules/tailwindcss{,/**}",
    "!node_modules/jsdom{,/**}",
    "!node_modules/@testing-library{,/**}",
    "!node_modules/globals{,/**}",
    "!node_modules/@esbuild{,/**}",
    "!node_modules/@esbuild-kit{,/**}",
    "!node_modules/esbuild{,/**}",
    "!node_modules/@babel{,/**}",
    "!node_modules/rollup{,/**}",
    "!node_modules/node-gyp{,/**}",
    "!node_modules/app-builder-bin{,/**}",
    "!node_modules/app-builder-lib{,/**}",
    "!node_modules/builder-util{,/**}",
    "!node_modules/builder-util-runtime{,/**}",
    "!node_modules/7zip-bin{,/**}",
    "!node_modules/7zip-min{,/**}",
    "!node_modules/electron{,/**}",
    "!node_modules/@electron/rebuild{,/**}",
    "!node_modules/caniuse-lite{,/**}",
    "!node_modules/lucide-react/dist/cjs{,/**}",
    "!node_modules/lucide-react/dist/umd{,/**}",
    "!node_modules/lucide-react/dist/*.d.ts",
    "!node_modules/drizzle-orm/{pg-core,mysql-core,singlestore-core,better-sqlite3,neon,planetscale,d1,expo-sqlite,libsql,turso,bun-sqlite,sql-js,durable-sqlite,aws-data-api,vercel-postgres,pglite,knex,kysely,prisma,supabase}{,/**}",
    "!node_modules/drizzle-orm/{op-sqlite,sqlite-proxy,neon-http,neon-serverless,planetscale-serverless,mysql-proxy,pg-proxy,singlestore-proxy,xata-http}{,/**}"
  ],
  "asar": true,
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*"
  ],
  "mac": {
    "target": ["dmg", "zip"],
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "identity": null,
    "hardenedRuntime": false
  },
  "win": {
    "target": ["nsis", "portable"],
    "artifactName": "${productName}-${version}-setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  }
}
